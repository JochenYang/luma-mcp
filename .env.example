# 模型提供商选择：zhipu | siliconflow | qwen | volcengine | hunyuan | custom
MODEL_PROVIDER=zhipu

# ========== Zhipu AI (推荐 - GLM-4.6V) ==========
# 获取API Key: https://open.bigmodel.cn/
ZHIPU_API_KEY=your-zhipu-api-key-here
MODEL_NAME=glm-4.6v

# ========== SiliconFlow (免费 - DeepSeek-OCR) ==========
# 获取API Key: https://siliconflow.cn/
# SILICONFLOW_API_KEY=your-siliconflow-api-key
# MODEL_NAME=deepseek-ai/DeepSeek-OCR

# ========== 阿里云 Qwen (Qwen3-VL-Flash) ==========
# 获取API Key: https://dashscope.aliyun.com/
# DASHSCOPE_API_KEY=your-dashscope-api-key
# MODEL_NAME=qwen3-vl-flash

# ========== 火山方舟 Volcengine (Doubao-Seed-1.6) ==========
# 获取API Key: https://console.volcengine.com/ark
# VOLCENGINE_API_KEY=your-volcengine-api-key
# MODEL_NAME=doubao-seed-1-6-flash-250828
# 可选模型:
# - doubao-seed-1-6-flash-250828 (性价比高，256k上下文)
# - doubao-seed-1-6-vision-250815 (视觉优化，64k输出)
# - doubao-seed-1-6-lite-251015 (轻量级)
# 注意: 使用控制台中的实际模型ID

# ========== 腾讯混元 Hunyuan (Hunyuan-T1-Vision) ==========
# 获取 API Key: https://console.cloud.tencent.com/hunyuan
# HUNYUAN_API_KEY=your-hunyuan-api-key
# MODEL_NAME=hunyuan-t1-vision-20250916

# ========== 自定义 Provider (任意 OpenAI 兼容端点) ==========
# 必填：MODEL_PROVIDER=custom + 以下三项
# CUSTOM_API_KEY=sk-your-key
# CUSTOM_BASE_URL=https://your-endpoint.com/v1
# CUSTOM_MODEL_NAME=your-model-name
#
# 可选配置（都有默认值）：
# CUSTOM_AUTH_HEADER=bearer         # bearer | x-api-key | custom
# CUSTOM_PATH=/chat/completions     # API 路径
# CUSTOM_TIMEOUT_MS=60000           # 超时毫秒
# CUSTOM_THINKING_MODE=disabled     # disabled | openai | qwen_extra_body
#
# 自定义 Header 示例（authHeader=custom 时使用）：
# CUSTOM_AUTH_HEADER=custom
# CUSTOM_AUTH_HEADER_VALUE="X-API-Key: {{key}}"   # {{key}} 会被替换为 API Key
#
# 适用场景：OpenAI、OpenRouter、Together AI、Anthropic 代理、本地 vLLM/Ollama 等

# ========== 通用参数 ==========
MAX_TOKENS=16384
TEMPERATURE=0.7
TOP_P=0.7
ENABLE_THINKING=true
